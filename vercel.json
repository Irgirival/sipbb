{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "server.js"
    },
    {
      "src": "/admin(/?)",
      "dest": "frontend/admin/index.html"
    },
    {
      "src": "/admin/(.*)",
      "dest": "frontend/admin/index.html"
    },
    {
      "src": "/pbb(/?)",
      "dest": "frontend/public/pbb.html"
    },
    {
      "src": "/uploads/(.*)",
      "dest": "uploads/$1"
    },
    {
      "src": "/(.*)\\.(html|css|js|png|jpg|jpeg|gif|svg|ico|woff|woff2|ttf|eot)",
      "dest": "frontend/public/$1.$2"
    },
    {
      "src": "/(.*)",
      "dest": "frontend/public/index.html"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
