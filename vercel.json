{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    },
    {
      "src": "frontend/**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "server.js"
    },
    {
      "src": "/admin(.*)",
      "dest": "frontend/admin/index.html"
    },
    {
      "src": "/pbb(.*)",
      "dest": "frontend/pbb.html"
    },
    {
      "src": "/uploads/(.*)",
      "dest": "uploads/$1"
    },
    {
      "src": "/(.*)",
      "dest": "frontend/public/index.html"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
